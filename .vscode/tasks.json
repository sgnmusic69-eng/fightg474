{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "cmake",
            "command": "configure",
            "preset": "Debug",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build",
            "type": "cmake",
            "command": "build",
            "preset": "Debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "OpenOCD: Flash",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f", "interface/stlink.cfg",
                "-f", "target/stm32g4x.cfg",
                "-c", "program ${command:cmake.launchTargetPath} verify reset exit"
            ],
            "problemMatcher": []
        }
    ]
}
